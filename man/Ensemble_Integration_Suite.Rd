\subsection{Method \code{plot_Top_Feature_Weights()}}{
Plot the features with the highest absolute weights in each factor
(component), per omics type and multi-omics integration method.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$plot_Top_Feature_Weights(
  nFeatures = 10,
  Scale = TRUE
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{nFeatures}}{Number of features to plot for each factor. Default is
10.}

\item{\code{Scale}}{Whether to scale the data from the different omics types, to
make the weights more comparable between omics types. Default is \code{TRUE}.}
}
\if{html}{\out{</div>}}
}
}
