\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-plot_Heatmap_Cluster}{}}}
\subsection{Method \code{plot_Heatmap_Cluster()}}{
Interactive heatmap with sample clustering results per omics type.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$plot_Heatmap_Cluster(
  FeatureClustering = TRUE,
  MethodResults = "all",
  YFontSize = 5,
  XFontSize = 5
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{FeatureClustering}}{Whether to order the features on the Y-axis
based on hierarchical clustering. Default is \code{TRUE}. If \code{FALSE}, the
features will be ordered as in the preprocessed datasets.}

\item{\code{MethodResults}}{For which clustering assignment the heatmap is to be
plotted. Must be one of: \code{"all"} (default), \code{"MoCluster"}, \code{"jNMF"}, \code{"iNMF"},
\code{"LRAcluster"}, \code{"COCA"}, \code{"GAUDI"}, \code{"SNF"}, \code{"MDS"} or \code{"CCA"}. If all is
selected, heatmaps with cluster assignments are created for all run
methods.}

\item{\code{YFontSize}}{Font size of the feature labels on the Y-axis. Default
is 5.}

\item{\code{XFontSize}}{Font size of the sample labels on the X-axis. Default
is 5.}
}
\if{html}{\out{</div>}}
}
}
