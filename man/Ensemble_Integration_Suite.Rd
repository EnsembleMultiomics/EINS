\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-run_Factor_Clustering}{}}}
\subsection{Method \code{run_Factor_Clustering()}}{
Cut the factor hierarchical clustering tree to create factor
clusters. Can be done either using the calculated optimal factor
cluster numbers, or with user argument.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$run_Factor_Clustering(Clusters = NULL)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{Clusters}}{Number of clusters in which to cut the factor
hierarchical clustering tree. Default is \code{NULL.} If \code{NULL}, the
optimal factor cluster numbers calculated with
\code{run_Factor_Optimal_Cluster} are used.}
}
\if{html}{\out{</div>}}
}
}
