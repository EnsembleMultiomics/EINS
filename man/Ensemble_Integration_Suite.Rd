\subsection{Method \code{plot_Scatterplot()}}{
Interactive scatterplot of samples in the factors
(components/dimensions) for methods which have CoordData (MoCluster,
MCIA, LRAcluster, MOFA and GAUDI).
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$plot_Scatterplot(
  XAxis = 1,
  YAxis = 2,
  YFontSize = 15,
  XFontSize = 15,
  Width = 5,
  Height = 5,
  MetadataFeature = NULL
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{XAxis}}{Integer, factor (component/dimension) to plot on the X-axis.
Default is 1.}

\item{\code{YAxis}}{Integer, factor (component/dimension) to plot on the Y-axis.
Default is 2.}

\item{\code{YFontSize}}{Size of the Y-axis title. Default is 15.}

\item{\code{XFontSize}}{Size of the X-axis title. Default is 15.}

\item{\code{Width}}{Width of the scatterplot. Default is 5.}

\item{\code{Height}}{Height of the scatterplot. Default is 5.}

\item{\code{MetadataFeature}}{Name of the metadata feature used as the shape of
the dots. Must be a string with the name of the metadata feature as in
the metadata files. This metadata feature needs to be available in the
metadatafiles of all omics types.}
}
\if{html}{\out{</div>}}
}
}
