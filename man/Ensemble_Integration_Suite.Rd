\if{html}{\out{<a id="method-Ensemble_Integration_Suite-run_Over_Represenation"></a>}}
\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-run_Over_Represenation}{}}}
\subsection{Method \code{run_Over_Represenation()}}{
Perform overrepresentation analysis from package ClusterProfiler
on the clustered ensembled features to determine if features with
similar biological functions group together in across multi-omics
integration methods. Uses enrichment GO categories from the genome
wide annotation database for human as provided in package
org.Hs.eg.db. Requires ensemble feature hierarchical clustering to
have been performed with \code{run_Feature_Ensemble_HClust} and a cluster
assignment to have been created with \code{run_Feature_Clustering}. Only
available for gene-based omics types (genomics, transcriptomics,
methylation etc.).
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$run_Over_Represenation(
  Method = "Average",
  OmicsName,
  GeneNameType,
  Subontologies = "ALL",
  pValue = 0.05,
  pAdjustment = "BH",
  qValue = 0.2,
  MinGenesPerTerm = 10,
  MaxGenesPerTerm = 500
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{Method}}{Which ensemble feature clustering result is to be used.
Must be one of" \code{"Average"} or \code{"Concatenation"}. Default is \code{"Average"}.}

\item{\code{OmicsName}}{For which omics dataset the overrepresentation analysis
is to be performed. Only genetics-based omics types can be utilized in the
genome wide annotation database.}

\item{\code{GeneNameType}}{Keytype of the feature name for the omics dataset.
Must be one of: \code{"ENTREZID"}, \code{"PFAM"}, \code{"IPI"}, \code{"PROSITE"}, \code{"ACCNUM"},
\code{"ALIAS"}, \code{"CHR"}, \code{"CHRLOC"}, \code{"CHRLOCEND"}, \code{"ENZYME"}, \code{"MAP"},
\code{"PATH"}, \code{"PMID"}, \code{"REFSEQ"}, \code{"SYMBOL"}, \code{"UNIGENE"}, \code{"ENSEMBL"},
\code{"ENSEMBLPROT"}, \code{"ENSEMBLTRANS"}, \code{"GENENAME"}, \code{"UNIPROT"}, \code{"GO"},
\code{"EVIDENCE"}, \code{"ONTOLOGY"}, \code{"GOALL"}, \code{"EVIDENCEALL"}, \code{"ONTOLOGYALL"},
\code{"OMIM"} or \code{"UCSCKG"}.}

\item{\code{Subontologies}}{Which ontology to use. Must be one of: \code{"ALL"}
(default), \code{"MF"}, \code{"BP"} or \code{"CC"}.}

\item{\code{pValue}}{Cutoff value for the p-value. Default is 0.05.}

\item{\code{pAdjustment}}{Method for the p-value adjustment. Must be one of:
\code{"BH"} (default), \code{"holm"}, \code{"hochberg"}, \code{"hommel"}, \code{"bonferroni"},
\code{"BY"}, \code{"fdr"} or \code{"none"}.}

\item{\code{qValue}}{Cutoff for the q-value. Default is 0.2.}

\item{\code{MinGenesPerTerm}}{Minimal number of genes annotated per ontology
term to be included for testing. Default is 10.}

\item{\code{MaxGenesPerTerm}}{Maximum number of genes annotated per ontology
term to be included for testing. Default is 500.}
}
\if{html}{\out{</div>}}
}
}
\if{html}{\out{<hr>}}
