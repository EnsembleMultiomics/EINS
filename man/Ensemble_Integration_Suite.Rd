\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-plot_Dendrogram}{}}}
\subsection{Method \code{plot_Dendrogram()}}{
Plot all previously created dendrograms with metadata features
labeled in colored bars.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$plot_Dendrogram(
  Data,
  Clusters = NULL,
  MetadataFeatures,
  LabelMetadata,
  MetadataHeight = 0,
  LabelSize = 1,
  BarLabelSize = 1
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{Data}}{Which previously created dendrogram to plot. Must be one of:
\itemize{
\item \code{"Single"}: Single omics sample hierarchical clustering results. Will
plot the dendrograms for all omics types provided.
\item \code{"Ensemble MDS"}: Ensemble MDS sample hierarchical clustering results.
\item \code{"Ensemble Factor"}: Ensemble factor hierarchical clustering results,
as calculated with \code{run_Feature_Ensemble_HClust} with \code{Method}
\code{"Concatenation"}.
\item \code{"Ensemble Feature Average"}: Ensemble feature hierarchical
clustering results, as calculated with \code{run_Feature_Ensemble_HClust}
with \code{Method} \code{"Average"}.
\item \code{"Ensemble Feature Concatenation"}: Ensemble feature hierarchical
clustering results, as calculated with \code{run_Feature_Ensemble_HClust}
with \code{Method} \code{"Concatenation"}.
\item \code{"Multi-Omics Feature"}: Feature hierarchical clustering results per
multi-omics integration method, as calculated with
\code{run_Multi_Omics_Feature_HClust}.
}}

\item{\code{Clusters}}{Number of clusters to color the dendrogram branches for.
If \code{NULL}, the branches will be black.}

\item{\code{MetadataFeatures}}{Names of the sample metadata features to be
included in colored bars below the dendrogram. A string vector with the
names of the metadata features as in the metadata files should be
provided. Can be used in \code{Data} = \code{"Single"} and \code{Data} =
\code{"Ensemble MDS"}.}

\item{\code{LabelMetadata}}{Name of the metadata feature for which the sample
labels should be colored. Must be a sting with the name of the metadata
feature as in the metadata files. Can be used in \code{Data} = \code{"Single"} and
\code{Data} = \code{"Ensemble MDS"}.}

\item{\code{MetadataHeight}}{Height of the colored bars with metadata
information. Default is 0. If 0 puts the colored bars in the dendrogram,
choose a negative integer. For \code{Data} = \code{"Ensemble MDS"},
\code{"Ensemble Feature Average"} or \code{"Ensemble Feature Concatenation"}, a
single integer should be provided. For \code{Data} = \code{"Single"} or
\code{"Multi-Omics Feature"}, a vector of integers with the same length as the
number of omics datasets must be provided.}

\item{\code{LabelSize}}{Size of the label beneath the dendrogram. Default is 1.}

\item{\code{BarLabelSize}}{Size of the label of the colored bars. Default is 1.}
}
\if{html}{\out{</div>}}
}
}
