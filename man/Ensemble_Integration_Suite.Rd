\if{html}{\out{<a id="method-Ensemble_Integration_Suite-run_Optimal_Cluster_Number"></a>}}
\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-run_Optimal_Cluster_Number}{}}}
\subsection{Method \code{run_Optimal_Cluster_Number()}}{
Calculate the optimal cluster number for integrated data using
NbClust. Performs data integration with seven methods that provide
sample by factor/component matrices: MoCluster, MCIA, jNMF, iNMF,
LRAcluster, MOFA and GAUDI. Integration methods are performed with
default parameters. A range of factors/components can be
provided, for multiple integration results to be used. NbClust is
then performed on these matrices. Multiple NbClust indexes are
calculated per matrix. All results from NbClust indexes for all
matrices are combined and the mean, mode and median optimal cluster
number are calculated. The user can then determine the preferred
cluster number.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$run_Optimal_Cluster_Number(
  Components = NULL,
  NbClustDistance = "euclidean",
  NbClustMinClust = 2,
  NbClustMaxClust = 12,
  NbClustMethod = "ward.D2",
  NbClustIndex = "all",
  NbClustAlphaBeale = 0.1
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{Components}}{Numerical or range of the components/factors to perform
the integrations with.}

\item{\code{NbClustDistance}}{String with the distance measure to be used for
the NbClust dissimilarity matrix computation. Must be one of:
\code{"euclidean"}, \code{"maximum"}, \code{"manhattan"}, \code{"canberra"}, \code{"binary"} or
\code{"minkowski"}. Default is \code{"euclidean"}.}

\item{\code{NbClustMinClust}}{Minimal number of clusters considered by NbClust.
Value between 1 and (number of objects - 1). Default is 2.}

\item{\code{NbClustMaxClust}}{Maximum number of clusters considered by NbClust.
Value between 2 and (number of object -2), but larger than
NbClustMinClust. Default is 12.}

\item{\code{NbClustMethod}}{The cluster analysis method used by NbClust. Must be
one of: \code{"ward.D"}, \code{"ward.D2"}, \code{"single"}, \code{"complete"}, \code{"average"},
\code{"mcquitty"}, \code{"median"}, \code{"centroid"}, \code{"kmeans"}. Default is
\code{"ward.D2"}.}

\item{\code{NbClustIndex}}{Indexes to be calculated by NbClust. Must be one of:
\code{"kl"}, \code{"ch"}, \code{"hartigan"}, \code{"ccc"}, \code{"scott"}, \code{"marriot"}, \code{"trcovw"},
\code{"tracew"}, \code{"friedman"}, \code{"rubin"}, \code{"cindex"}, \code{"db"}, \code{"silhouette"},
\code{"duda"}, \code{"pseudot2"}, \code{"beale"}, \code{"ratkowsky"}, \code{"ball"},
\code{"ptbiserial"}, \code{"gap"}, \code{"frey"}, \code{"mcclain"}, \code{"gamma"}, \code{"gplus"},
\code{"tau"}, \code{"dunn"}, \code{"hubert"}, \code{"sdindex"}, \code{"dindex"}, \code{"sdbw"}, \code{"all"}
(all indices except GAP, Gamma, Gplus and Tau), \code{"alllong"} (all indices
with Gap, Gamma, Gplus and Tau included). Default is \code{"all"}.}

\item{\code{NbClustAlphaBeale}}{Numerical, significance value for Beale's index.
Default is 0.1.}
}
\if{html}{\out{</div>}}
}
}
\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-Ensemble_Integration_Suite-run_Single_Omics_Clustering"></a>}}
\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-run_Single_Omics_Clustering}{}}}
\subsection{Method \code{run_Single_Omics_Clustering()}}{
Uses model-based clustering method HDDC from the HDclassif package
to provide clustering results for individual omics datasets.
This is a specific parametrization of the Gaussian mixture model to
work with high dimensional data. When running
\code{run_Single_Omics_Clustering}, clustering is performed on all omics
datasets imported into the object.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$run_Single_Omics_Clustering(
  MinClust = 2,
  MaxClust = 12,
  HDModel = "AkjBkQkDk",
  HDThreshold = 0.2,
  HDCriterion = "BIC",
  HDItermax = 200,
  HDEps = 0.001,
  HDAlgo = "EM",
  HDD_select = "Cattell",
  HDInit = "kmeans",
  HDInit.vector,
  HDMini.nb = c(5, 10),
  HDScaling = FALSE,
  HDMin.individuals = 2,
  HDNoise.ctrl = 1e-08,
  HDMc.cores = 1,
  HDNb.rep = 1,
  HDKeepAllRes = TRUE,
  HDKmeans.control = list(),
  HDD_max = 100,
  HDSubset = Inf
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{MinClust}}{Minimum number of clusters considered by the model.
Default is 2.}

\item{\code{MaxClust}}{Maximum number of clusters considered by the model.
Value needs to be at least (MinClust + 1). Default is 12.}

\item{\code{HDModel}}{Name of the model. Must be one or combination of:
\code{"AkjBkQkDk"} (default), \code{"AkBkQkDk"}, \code{"ABkQkDk"}, \code{"AkjBQkDk"},
\code{"AkBQkDk"}, \code{"ABQkDk"}, \code{"AkjBkQkD"}, \code{"AkBkQkD"}, \code{"ABkQkD"},
\code{"AkjBQkD"}, \code{"AkBQkD"}, \code{"ABQkD"}, \code{"AjBQD"} or \code{"ABQD"}. If a
combination of models is selected, the model which maximizes the BIC
criterion is kept. All models can be run with \code{"ALL"}.}

\item{\code{HDThreshold}}{Threshold used in Cattell's Scree-Test. Must be
between 0 and 1. Default is 0.2.}

\item{\code{HDCriterion}}{Criterion used to select the best model. Either
\code{"BIC"} (default) or \code{"ICL"}.}

\item{\code{HDItermax}}{Maximum number of iteration allowed. Default is 200.}

\item{\code{HDEps}}{Double positive, default is 0.001. Used as the stopping
criterion: the algorithm stops if the difference between two successive
log-likelihoods is lower than \code{"HDEps"}.}

\item{\code{HDAlgo}}{The algorithm to be used. Must be one of: \code{"EM"}
(expectation-maximization), \code{"CEM"} (classification EM), or \code{"SEM"}
(stochastic EM). Default is \code{"EM"}.}

\item{\code{HDD_select}}{Method to select the intrinsic dimension. Must be one
of: \code{"Cattell"} (default), or \code{"BIC"}.}

\item{\code{HDInit}}{Method to initialize the EM algorithm. Must be one of:
\code{"kmeans"} (default), \code{"param"}, \code{"random"}, \code{"mini-em"} or \code{"vector"}.
If \code{"vector"} is selected, argument \code{"HDInit.vector"} should be added.}

\item{\code{HDInit.vector}}{Vector of integers or factors of the same length as
the number of samples. Only used if \code{"HDInit"} is \code{"vector"}.}

\item{\code{HDMini.nb}}{Vector of 2 integers. Parameter used in \code{"mini-em"}
initialization. First integer indicates the amount of times the algorithm
will be launched, the second integer indicates how many iterations are
performed each launch. Default is \code{"c(5,10)"}.}

\item{\code{HDScaling}}{Whether to perform scaling on the dataset. Default is
\code{FALSE}.}

\item{\code{HDMin.individuals}}{The minimum number of samples per cluster. Must
be 2 (default) or greater.}

\item{\code{HDNoise.ctrl}}{Parameter to minimize the intrinsic dimension
selected. Dimensions with eigenvalues lower than \code{"HDNoise.ctrl"} are not
used. Default is 1e-8.}

\item{\code{HDMc.cores}}{Whether parallel computing is used. Default is 1,
indicating no parallel computing. If \code{"HDMc.cores"} is larger than 1,
parallel computing is used with \code{"HDMc.cores"} cores.}

\item{\code{HDNb.rep}}{Number of times each estimation is repeated, with the
estimation with the highest log-likelihood kept. Default is 1 (no
repetition).}

\item{\code{HDKeepAllRes}}{Whether results of all runs should be kept. Default
is \code{TRUE}.}

\item{\code{HDKmeans.control}}{List of kmeans initialization parameters:
\code{"iter.max"}, \code{"nstart"} and \code{"algorithm"}.}

\item{\code{HDD_max}}{Maximum number of dimensions to be computed. Default is
100.}

\item{\code{HDSubset}}{Clustering can be performed on a subset of the data. If
\code{"HDSubset"} is smaller than the number of samples, clustering is
performed on a random subset of that size. Then, the posterior of the
clustering is computed on the full sample. Default is \code{Inf}, indicating
no subsetting.}
}
\if{html}{\out{</div>}}
}
}
\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-Ensemble_Integration_Suite-run_Single_Omics_Hierarchical_Clustering"></a>}}
\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-run_Single_Omics_Hierarchical_Clustering}{}}}
\subsection{Method \code{run_Single_Omics_Hierarchical_Clustering()}}{
Sample hierarchical clustering to be performed on each individual
omics dataset. When running \code{run_Single_Omics_Hierarchical_Clustering},
hierarchical clustering is performed on all omics datasets imported
into the object.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$run_Single_Omics_Hierarchical_Clustering(
  Distance = "euclidean",
  MinkowskiPower = NULL,
  Linkage = "ward.D2"
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{Distance}}{Distance measure to be used. Must be one of:
\code{"euclidean"} (default), \code{"maximum"}, \code{"manhattan"}, \code{"canberra"},
\code{"binary"} or \code{"minkowski"}. If \code{"minkowski"} is selected, argument
\code{"MinkowskiPower"} needs to be included.}

\item{\code{MinkowskiPower}}{Power of the Minkowski distance. Default is NULL.}

\item{\code{Linkage}}{Agglomeration method to be used. Must be one of: \code{"ward.D"},
\code{"ward.D2"} (default), \code{"single"}, \code{"complete"}, \code{"average"}, \code{"mcquitty"},
\code{"median"} or \code{"centroid"}.}
}
\if{html}{\out{</div>}}
}
}
\if{html}{\out{<hr>}}
\if{html}{\out{<a id="method-Ensemble_Integration_Suite-run_MoCluster"></a>}}
\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-run_MoCluster}{}}}
\subsection{Method \code{run_MoCluster()}}{
Perform multi-omics integration and sample clustering using MoCluster
from the mogsa package.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$run_MoCluster(
  Clusters = NULL,
  Components = NULL,
  Method = "globalScore",
  Option = "lambda1",
  k = "all",
  Center = TRUE,
  Scale = FALSE,
  MaxIter = 1000,
  svdSolver = "fast.svd",
  Distance = "euclidean",
  MinkowskiPower = NULL,
  Linkage = "complete"
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{Clusters}}{The number of sample clusters to be created. Can be a
single integer to calculate a single clustering assignment, or a range to
calculate multiple clustering assignment.}

\item{\code{Components}}{The number of components to reduce the data to. Needs
be a single integer.}

\item{\code{Method}}{String to indicate the integration approach. Must be one of:
\code{"globalScore"} (consensus PCA), \code{"blockScore"} (generalized canonical
correlation analysis) or \code{"blockLoading"} (multiple co-inertia analysis).
Default is \code{"globalScore"}.}

\item{\code{Option}}{String to indicate how matrices should be normalized. Must
be one of: \code{"lambda1"} (matrix divided by first singular value),
\code{"inertia"} (matrix divided by its total inertia) or \code{"uniform"} (no
normalization). Default is \code{"lambda1"}.}

\item{\code{k}}{The number of non-zero coefficients for the variable loading
vectors to determine the sparsity. If \code{k} >= 1, \code{k} is the absolute
number of non-zero coefficients. If 0  < \code{k} < 1, \code{k} is the proportion
of non-zero coefficients. A single value or vector with length equal to
the number of omics datasets can be provided. Default is \code{"all"},
indicating no sparsity.}

\item{\code{Center}}{Whether the variables should be centered. Default is \code{TRUE}.}

\item{\code{Scale}}{Whether the variables should be scaled. Default is \code{FALSE}.}

\item{\code{MaxIter}}{Maximum number of iterations in the algorithm. Default is
1000.}

\item{\code{svdSolver}}{String to indicate the method used for singular value
decomposition. Must be one of: \code{"fast.svd"} (default), \code{"svd"} or
\code{"propack"}. \code{"fast.svd"} has a good compromise between speed and
robustness compared to \code{"svd"} (slower but more robust) and \code{"propack"}
(faster but less likely to converge).}

\item{\code{Distance}}{Distance measure to be used for distance matrix
calculation of the integrated data. Must be one of: \code{"euclidean"}
(default), \code{"maximum"}, \code{"manhattan"}, \code{"canberra"}, \code{"binary"} or
\code{"minkowski"}. If \code{"minkowski"} is selected, argument \code{"MinkowskiPower"}
needs to be included.}

\item{\code{MinkowskiPower}}{Power of the Minkowski distance. Default is NULL.}

\item{\code{Linkage}}{Agglomeration method to be used for the hierarchical
clustering. Must be one of: \code{"ward.D"}, \code{"ward.D2"}, \code{"single"},
\code{"complete"} (default), \code{"average"}, \code{"mcquitty"}, \code{"median"} or
\code{"centroid"}.}
}
\if{html}{\out{</div>}}
}
}
