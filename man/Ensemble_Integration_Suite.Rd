\if{html}{\out{<a id="method-Ensemble_Integration_Suite-plot_Sankey_Methods"></a>}}
\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-plot_Sankey_Methods}{}}}
\subsection{Method \code{plot_Sankey_Methods()}}{
Interactive Sankey plot of sample cluster results between methods.
Compares the cluster assignments of all multi-omics integration
methods which have the same number of clusters. Can only be performed
if multiple integration methods have calculated cluster assignments
for the same cluster number.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$plot_Sankey_Methods(
  MetadataFeature = NULL,
  Ensemble = TRUE,
  SNFDistance = "euclidean squared",
  AllPlots = TRUE
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{MetadataFeature}}{String of the sample metadata feature for which the
samples should be colored. The metadata feature need to be available
in the metadata files for all omics types.}

\item{\code{Ensemble}}{Whether to include the ensemble sample clustering results
to the Sankey plot. Must run \code{run_Ensemble_Sample_MDS} or
\code{run_Ensemble_Sample_CCA} first. Default is \code{TRUE}.}

\item{\code{SNFDistance}}{Which SNF distance calculated cluster assignment
should be included in the plot comparing different methods. To compare
the cluster assignments between SNF distances, an SNF-only Sankey plot
can be created, see parameter \code{AllPlots}. Must be one of:
\code{"euclidean squared"} (default), \code{"euclidean"}, \code{"manhattan"},
\code{"minkowksi 0.25"}, \code{"minkowski 0.5"}, \code{"minkowski 3"} or \code{"minkowski 4"}.}

\item{\code{AllPlots}}{Whether 3 plots should be created per cluster number:
\itemize{
\item Selected: All methods + specified \code{SNFDistance} cluster assignments.
\item SNF: All SNF distance cluster assignments.
\item Full: All methods cluster assignments with all SNF distances.
Default is \code{TRUE}. If \code{FALSE}, only the first option, with all methods
and the specified \code{SNFDistance} will be created.
}}
}
\if{html}{\out{</div>}}
}
}
