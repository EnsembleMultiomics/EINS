\if{latex}{\out{\hypertarget{method-Ensemble_Integration_Suite-run_jNMF}{}}}
\subsection{Method \code{run_jNMF()}}{
Perform multi-omics integration using joint non-negative matrix
factorization (jNMF) from the nnTensor package.
\subsection{Usage}{
\if{html}{\out{<div class="r">}}\preformatted{Ensemble_Integration_Suite$run_jNMF(
  Clusters = NULL,
  NMFAlgorithm = "KL",
  MaxIter = 100
)}\if{html}{\out{</div>}}
}

\subsection{Arguments}{
\if{html}{\out{<div class="arguments">}}
\describe{
\item{\code{Clusters}}{The number of sample clusters to be created. Can be a
single integer to calculate a single cluster assignment, or a range to
calculate multiple cluster assignments. In jNMF, the number of clusters
is the number of low dimensions or components created.}

\item{\code{NMFAlgorithm}}{String indicating algorithm for the divergence
between X and X-bar. Must be one of: \code{"KL"} (default), \code{"Frobenius"} or
\code{"IS"}.}

\item{\code{MaxIter}}{Number of iterations. Default is 100.}
}
\if{html}{\out{</div>}}
}
}
